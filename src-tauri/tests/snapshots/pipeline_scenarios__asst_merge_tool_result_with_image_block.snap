---
source: tests/pipeline_scenarios.rs
expression: run_normalized(msgs)
---
- role: assistant
  id: msg-1
  content_length: 1
  content:
    - type: tool-call
      tool_name: Bash
      tool_call_id: t1
      args_keys:
        - command
      args_text_length: 16
      has_result: true
      result_kind: string
      result_preview: file-a
      streaming_status: ~
  status:
    type: complete
    reason: stop
  streaming: ~
