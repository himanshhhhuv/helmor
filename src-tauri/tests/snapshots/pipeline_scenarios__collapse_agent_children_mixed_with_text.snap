---
source: tests/pipeline_scenarios.rs
expression: run_normalized(msgs)
---
- role: user
  id: msg-1
  content_length: 1
  content:
    - type: text
      text: investigate the bug
  status: ~
  streaming: ~
- role: assistant
  id: msg-2
  content_length: 2
  content:
    - type: tool-call
      tool_name: Agent
      tool_call_id: agent-2
      args_keys:
        - description
      args_text_length: 29
      has_result: true
      result_kind: string
      result_preview: analysis complete
      streaming_status: ~
      children_count: 3
      children:
        - type: collapsed-group
          category: search
          tools_count: 2
          active: false
          summary: Searched 2 patterns
        - type: text
          text: Now let me read the relevant files.
        - type: collapsed-group
          category: read
          tools_count: 2
          active: false
          summary: Read 2 files
    - type: text
      text: Found the bug in the collapse pass.
  status:
    type: complete
    reason: stop
  streaming: ~
