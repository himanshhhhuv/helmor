{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"noFallthroughCasesInSwitch": true,
		"types": ["node", "bun"],
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true
	},
	"include": ["src", "test"]
}
